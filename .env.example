APP_NAME=slogger
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_PORT=8097
APP_DOMAIN=http://localhost
APP_URL=${APP_DOMAIN}:${APP_PORT}

# logging
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# databases
DB_CONNECTION=mysql
DB_HOST=sl-mysql
DB_PORT=3306
DB_DATABASE=slogger
DB_USERNAME=root
DB_PASSWORD=_sl_password_312
DB_DOCKER_PORT=13306

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=file
SESSION_LIFETIME=120

# redis
REDIS_HOST=redis
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_DOCKER_PORT=16379

# rabbitmq
RABBITMQ_HOST=sl-rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=root
RABBITMQ_PASSWORD=_sl_passw0rd_44
RABBITMQ_QUEUE=default
RABBITMQ_DOCKER_PORT=6672
RABBITMQ_DOCKER_ADMIN_PORT=25672
RABBITMQ_ADMIN_URL=${APP_DOMAIN}:${RABBITMQ_DOCKER_ADMIN_PORT}

# mail
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# root user is set by default
# to find user id and group id on linux use commands `id -u` and `id -g`
DOCKER_USER_ID=1000
DOCKER_GROUP_ID=1000

XDEBUG_REMOTE_HOST=
XDEBUG_CLIENT_HOST=
PHP_IDE_CONFIG_SERVER_NAME=SL_PHPSTORM

# mongodb
MONGO_HOST=sl-mongo
MONGO_PORT=27017
MONGO_DOCKER_PORT=27070

MONGO_DATABASE_ADMIN=admin
MONGO_DATABASE_TRACES=traces
MONGO_DATABASE_TRACES_PERIODIC=tracesPeriodic
MONGO_DATABASE_LOGS=logs

MONGO_ADMIN_USERNAME=sl_admin
MONGO_ADMIN_PASSWORD=_sl_password_3124

MONGO_WIRED_TIGER_CACHE_SIZE_GB=10

# frontend
FRONTEND_DOCKER_PORT=3075
FRONTEND_DOCKER_LOCAL_COMMAND=dev-expose
FRONTEND_DOCKER_SERVER_COMMAND=preview-expose
FRONTEND_DOCKER_COMMAND=${FRONTEND_DOCKER_SERVER_COMMAND}

# reciever
RECIEVER_SOCKET_PORT=9030
RECIEVER_SOCKET_DOCKER_PORT=10031

# octane
## octane.roadrunner
OCTANE_RR_HOST=0.0.0.0
OCTANE_RR_PORT=9020
OCTANE_RR_RPC_HOST=0.0.0.0
OCTANE_RR_RPC_PORT=9010
OCTANE_RR_WORKERS=5
OCTANE_RR_MAX_WORKERS=15
OCTANE_RR_MAX_REQUESTS=500
OCTANE_RR_LOG_LEVEL=error
OCTANE_RR_DOCKER_PORT=10021

# modules.cleaner
QUEUE_TRACES_CLEANER_CONNECTION=${QUEUE_CONNECTION}
QUEUE_TRACES_CLEANER_NAME=traces-clearing
TRACES_LIFETIME_DAYS=3

# modules.trace
QUEUE_TRACE_TREE_CONNECTION=${QUEUE_CONNECTION}
QUEUE_TRACE_TREE_NAME=trace-tree
QUEUE_TRACE_TREE_WORKERS_COUNT=1

# sconcur
SCONCUR_HTTP_WORKER_COUNT=1
SCONCUR_HTTP_PANEL_PORT=28081
# full URL of the master telemetry panel stats endpoint as seen from php-fpm (master runs in the workers container)
SCONCUR_PANEL_HOST=http://workers:28081/api/stats
# docker port mappings (host:container) for the sconcur worker and telemetry panel
SCONCUR_HTTP_PORT=28080
SCONCUR_HTTP_DOCKER_PORT=17832
SCONCUR_PANEL_DOCKER_PORT=17833
SCONCUR_HTTP_ADMIN_TOKEN=
SCONCUR_HTTP_NAME=sconcur-http-server
SCONCUR_HTTP_ROTATE_DAYS=3
SCONCUR_HTTP_LOG_TO=both
SCONCUR_HTTP_RESTART_POLICY=always
SCONCUR_HTTP_SHUTDOWN_TIMEOUT_MS=10000
SCONCUR_HTTP_RESTART_BACKOFF_MS=200
SCONCUR_HTTP_MAX_RESTART_BACKOFF_MS=30000
SCONCUR_HTTP_ADDRESS=0.0.0.0:28080
SCONCUR_HTTP_REUSE_PORT=true
SCONCUR_HTTP_MAX_REQUESTS=0
SCONCUR_HTTP_MAX_CONCURRENCY=0
SCONCUR_HTTP_MAX_REQUEST_BODY=10485760
SCONCUR_HTTP_READ_HEADER_TIMEOUT_MS=10000
SCONCUR_HTTP_READ_TIMEOUT_MS=30000
SCONCUR_HTTP_WRITE_TIMEOUT_MS=30000
SCONCUR_HTTP_IDLE_TIMEOUT_MS=60000
SCONCUR_HTTP_HANDLER_TIMEOUT_MS=60000
SCONCUR_HTTP_SERVER_SHUTDOWN_TIMEOUT_MS=5000

# slogger
SLOGGER_ENABLED=false

SLOGGER_TOKEN=

## slogger.dispatcher
# one of: queue, file
SLOGGER_DISPATCHER=queue

## slogger.dispatcher.queue
SLOGGER_DISPATCHER_QUEUE_CONNECTION=rabbitmq
SLOGGER_DISPATCHER_QUEUE_NAME=slogger
SLOGGER_DISPATCHER_QUEUE_WORKERS_COUNT=5
# http, socket
SLOGGER_DISPATCHER_QUEUE_API_CLIENT=socket
SLOGGER_DISPATCHER_QUEUE_HTTP_CLIENT_URL=http://sl-workers:${OCTANE_RR_PORT}
SLOGGER_DISPATCHER_QUEUE_SOCKET_CLIENT_URL=tcp://sl-receiver:${RECIEVER_SOCKET_PORT}

## slogger.logging
SLOGGER_LOG_CHANNEL=slogger

## slogger.profiling
SLOGGER_PROFILING_ENABLED=false

SLOGGER_REQUESTS_HEADER_PARENT_TRACE_ID_KEY=x-parent-trace-id

## slogger.watchers
SLOGGER_LOG_REQUESTS_ENABLED=false
SLOGGER_LOG_COMMANDS_ENABLED=false
SLOGGER_LOG_DATABASE_ENABLED=false
SLOGGER_LOG_LOG_ENABLED=false
SLOGGER_LOG_SCHEDULE_ENABLED=false
SLOGGER_LOG_JOBS_ENABLED=false
SLOGGER_LOG_MODEL_ENABLED=false
SLOGGER_LOG_GATE_ENABLED=false
SLOGGER_LOG_EVENT_ENABLED=false
SLOGGER_LOG_MAIL_ENABLED=false
SLOGGER_LOG_NOTIFICATION_ENABLED=false
SLOGGER_LOG_CACHE_ENABLED=false
SLOGGER_LOG_DUMP_ENABLED=false
SLOGGER_LOG_HTTP_ENABLED=false
