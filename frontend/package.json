{
  "name": "slogger.frontend.local",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev-expose": "vite --host=0.0.0.0 --port=3000",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "preview-expose": "vite preview --host=0.0.0.0 --port=3000",
    "generate": "npx swagger-typescript-api generate -p json-schemes/admin-api-openapi-scheme.json -o ./src/api-schema -n admin-api-schema.ts --route-types --responses --enum-names-as-values --union-enums"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@vue-flow/controls": "^1.1.3",
    "@vue-flow/core": "^1.48.2",
    "@vue-flow/minimap": "^1.5.4",
    "chart.js": "^4.5.1",
    "element-plus": "^2.13.6",
    "pinia": "^3.0.4",
    "swagger-typescript-api": "^13.6.6",
    "vue": "^3.5.32",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "typescript": "^6.0.2",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^8.0.3",
    "vue-tsc": "^3.2.6"
  }
}
